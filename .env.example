# ParserRIba local settings example.
# Copy this file to `.env` and fill only local values.

# Optional proxy for Camoufox/Playwright.
# Keep real credentials only in `.env`, never commit them.
# Example:
# PARSER_PROXY=http://login:password@host:port
PARSER_PROXY=

# Optional proxy pool for retries/rotation. Use newline, comma or semicolon.
# Keep real credentials only in `.env`.
# Example:
# PARSER_PROXIES=http://login:password@host1:port;http://login:password@host2:port
PARSER_PROXIES=

# Optional retry count for Pyaterochka parser/smoke attempts.
PARSER_ATTEMPTS=3

# Enable Camoufox GeoIP alignment when GeoLite2-City.mmdb exists.
# Download the database with:
# python download_geoip.py
PARSER_GEOIP=0

# Fingerprint profile. Camoufox generates BrowserForge fingerprints internally;
# these values constrain that generation without hardcoding a fake user agent.
CAMOUFOX_FINGERPRINT_OS=windows
CAMOUFOX_LOCALE=ru-RU
CAMOUFOX_HUMANIZE=1.5
CAMOUFOX_BLOCK_IMAGES=1
CAMOUFOX_BLOCK_WEBRTC=1
CAMOUFOX_BLOCK_WEBGL=0
CAMOUFOX_SCREEN_MIN_WIDTH=1366
CAMOUFOX_SCREEN_MAX_WIDTH=1920
CAMOUFOX_SCREEN_MIN_HEIGHT=768
CAMOUFOX_SCREEN_MAX_HEIGHT=1080

# Optional fixed window/WebGL settings. Leave empty unless smoke reports show
# a concrete mismatch that must be pinned.
CAMOUFOX_WINDOW_WIDTH=
CAMOUFOX_WINDOW_HEIGHT=
CAMOUFOX_FINGERPRINT_PRESET=
CAMOUFOX_WEBGL_VENDOR=
CAMOUFOX_WEBGL_RENDERER=

# Optional custom Camoufox executable path.
# On the tested Windows setup:
# C:\CamoufoxBrowser\camoufox-135.0.1-beta.24-win.x86_64\camoufox.exe
CAMOUFOX_BIN=

# Optional explicit GeoIP database path.
GEOIP_PATH=
