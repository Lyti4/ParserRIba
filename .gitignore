```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
pip-log.txt
pipenv.lock
requirements.txt.bak

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
.env.*

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE specific
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# OS generated files
.DS_Store
Thumbs.db
```