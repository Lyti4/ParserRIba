```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.out
*.exe
*.dll
*.so
*.a

# Testing and coverage
.coverage
htmlcov/
coverage/
.pytest_cache/
.mypy_cache/

# Editors
.vscode/
.idea/
```